# ---- FinalWhistle environment (copy to .env.local; never commit real secrets) ----

# Solana cluster: "devnet" (default for the hackathon) or "mainnet-beta"
CLUSTER=devnet

# RPC endpoints — at least two so solana-resilience-kit can fail over.
RPC_PRIMARY=https://api.devnet.solana.com
RPC_BACKUP=https://api.devnet.solana.com
# Optional Helius key enables the account-aware fee oracle.
HELIUS_API_KEY=

# FinalWhistle program id (pinned; same on every cluster).
FINALWHISTLE_PROGRAM_ID=GSud9smJwwV6QhDLd2hmSQPShj1w8zYumz5BL3snbmao

# USDC mint used as collateral (devnet uses a project-minted token).
USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr

# Keeper signer secret key (base58 or JSON array). Use `wrangler secret put` in prod.
KEEPER_SECRET_KEY=

# TxLINE API token + JWT (obtained via the guest-auth + subscribe + activate flow).
TXLINE_JWT=
TXLINE_API_TOKEN=

# Frontend (Next.js public vars).
NEXT_PUBLIC_CLUSTER=devnet
NEXT_PUBLIC_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_RPC_BACKUP=https://api.devnet.solana.com
NEXT_PUBLIC_FINALWHISTLE_PROGRAM_ID=GSud9smJwwV6QhDLd2hmSQPShj1w8zYumz5BL3snbmao
NEXT_PUBLIC_USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr
NEXT_PUBLIC_API_BASE=http://localhost:7791
