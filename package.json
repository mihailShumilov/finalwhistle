{
  "name": "finalwhistle",
  "version": "0.1.0",
  "private": true,
  "description": "Permissionless parametric prop-bet protocol on Solana that self-settles via TxLINE Merkle proofs (CPI into validate_stat).",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.2.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "spike": "pnpm --filter @finalwhistle/tests spike",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "26.0.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
