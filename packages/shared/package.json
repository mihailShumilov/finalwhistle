{
  "name": "@finalwhistle/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared types, predicate model, canonicalisation and TxLINE helpers for FinalWhistle.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
